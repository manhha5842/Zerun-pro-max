NODE_ENV=development
PORT=3000
API_HOST=127.0.0.1
API_ORIGIN=http://localhost:5173
WEB_ADMIN_DIST=apps/web-admin/dist

DATABASE_URL=file:C:/Users/manhh/AppData/Roaming/com.zerun.app/post_logs.sqlite
ZERUN_QUEUE_MODE=local
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-this-secret-before-production
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_DAYS=30

# ── Mã hoá credentials/session (AES-256-GCM) ────────────────────────────────
# Master key 32 bytes (base64). Sinh nhanh:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠ BACKUP key này ở nơi an toàn (password manager). MẤT KEY = mất toàn bộ
#   session/credentials đã mã hoá → phải đăng nhập lại tất cả tài khoản.
# Bỏ trống = không mã hoá (chỉ nên dùng khi dev). Đặt key rồi chạy migration:
#   tsx packages/db/src/migrate-encrypt.ts
ZERUN_MASTER_KEY=

MEDIA_STORAGE_DIR=storage/media
PUBLIC_BASE_URL=http://localhost:3000

CLOUDFLARE_TUNNEL_TOKEN=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
X_USERNAME=
X_PASSWORD=
THREADS_USERNAME=
THREADS_PASSWORD=
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
FACEBOOK_USERNAME=
FACEBOOK_PASSWORD=
ACCESSTRADE_API_KEY=
ACCESSTRADE_DEFAULT_CAMPAIGN_ID=

# ── AI Provider (9router / OpenAI-compatible) ──────────────────────────────
# 9router: đặt NINEROUTER_URL + NINEROUTER_KEY
# Hoặc OpenAI-compatible khác: đặt AI_BASE_URL + AI_API_KEY
NINEROUTER_URL=
NINEROUTER_KEY=
AI_BASE_URL=
AI_API_KEY=
# Model cụ thể (bỏ trống hoặc "auto" để tự lấy từ /v1/models)
AI_MODEL=auto

# ── Lazada Affiliate API ────────────────────────────────────────────────────
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_ACCESS_TOKEN=
LAZADA_REGION=VN

# ── Session/Profile Manager ─────────────────────────────────────────────────
# Thư mục lưu Playwright profile (mặc định: ./storage/sessions)
SESSION_STORAGE_DIR=storage/sessions
