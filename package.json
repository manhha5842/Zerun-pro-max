{
  "name": "zerun-pro-max",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @zerun/api",
    "dev:web": "npm run dev -w @zerun/web-admin",
    "build": "npm run typecheck && npm run build -w @zerun/web-admin",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/src/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
