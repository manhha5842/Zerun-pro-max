{
  "name": "zerun-pro-max",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cross-env PORT=3001 API_ORIGIN=http://localhost:3000 npm run dev -w @zerun/api",
    "dev:web": "npm run dev -w @zerun/web-admin",
    "build": "npm run typecheck && npm run build -w @zerun/web-admin",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/src/seed.ts",
    "db:encrypt": "tsx packages/db/src/migrate-encrypt.ts",
    "telegram:session": "tsx scripts/generate-telegram-session.ts",
    "start:api": "node -e \"process.chdir('apps/api') || true\" && npm run start -w @zerun/api",
    "build:web": "npm run build -w @zerun/web-admin",
    "preview:web": "npm run preview -w @zerun/web-admin"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prisma": "^6.19.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
